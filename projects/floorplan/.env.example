# ── 서버 설정 ──────────────────────────────────────
PORT=3000

# ── 서브경로 설정 ──────────────────────────────────
# mdBoard 등 기존 서버에 통합 시 설정
# 예: BASE_PATH=/floorplan  →  http://서버/floorplan 으로 접근
# 루트로 단독 서비스 시 비워두거나 삭제
BASE_PATH=/floorplan

# ── 권한 관리 ──────────────────────────────────────
# 관리자 토큰 (쉼표로 여러 명 설정)
ADMIN_TOKENS=your-secret-admin-token-here

# ── Google Drive 설정 ──────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/gdrive-service-account.json
GDRIVE_FOLDER_ID=your-google-drive-folder-id-here

# ── 로컬 폴백 (Drive 미설정 시) ────────────────────
USE_LOCAL_FALLBACK=true
LOCAL_DATA_DIR=./data
