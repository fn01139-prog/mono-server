PORT=3000
NODE_ENV=development

ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL (Railway에서 자동 주입)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# mdBoard
MDBOARD_PASSWORD=your_password_here
MDBOARD_API_KEY=your_api_key_here   # Claude Code 등 programmatic 접근용

# Portfolio
PORTFOLIO_PASSWORD=your_password_here

# campchecklist JWT
JWT_SECRET=change-me-in-production

# floorplan 관리자 토큰
ADMIN_TOKENS=your_admin_token

# travellog - Google Drive (사진 파일 저장)
GOOGLE_SERVICE_ACCOUNT=base64_encoded_service_account_json
DRIVE_FOLDER_ID=your_drive_folder_id

# campchecklist - Google Drive (Drive 동기화 옵션, 사용 시만 설정)
# GDRIVE_CLIENT_ID=
# GDRIVE_CLIENT_SECRET=
# GDRIVE_REFRESH_TOKEN=
# GDRIVE_FOLDER_ID=
