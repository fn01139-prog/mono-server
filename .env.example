PORT=3000
NODE_ENV=development

# Railway 배포 시: GitHub Pages 도메인을 콤마로 구분해서 입력
# 예) https://your-id.github.io,https://custom-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# mdBoard 에디터 인증 비밀번호 (설정하지 않으면 인증 없이 편집 가능)
MDBOARD_PASSWORD=your_password_here

# Portfolio 관리자(/portfolio/studio) 인증 비밀번호 (설정하지 않으면 인증 없이 접근 가능)
PORTFOLIO_PASSWORD=your_password_here

# 포트폴리오 데이터 경로 (필요 시 변경)
# PORTFOLIO_JSON_DIR=./projects/portfolio/data
